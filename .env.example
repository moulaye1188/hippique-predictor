# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=1

# Python Configuration
PYTHONUNBUFFERED=1

# Server Configuration
HOST=0.0.0.0
PORT=5000

# Database Configuration
DATABASE_PATH=/app/data/hippique.db

# Model Configuration
MODEL_PATH=/app/models/race_prediction_model.h5

# ML Configuration
INPUT_FEATURES=5
EPOCHS=30
BATCH_SIZE=16
LEARNING_RATE=0.001
