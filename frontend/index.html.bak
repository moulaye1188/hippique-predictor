<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Prédiction Courses Hippiques - Deep Learning</title>
    <link rel="stylesheet" href="style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <div class="container">
        <header>
            <h1>🐴 Prédicteur de Courses Hippiques</h1>
            <p class="subtitle">Analyse intelligente basée sur Deep Learning</p>
        </header>

        <main>
            <!-- Status Bar -->
            <div id="statusBar" class="status-bar hidden">
                <span id="statusText"></span>
            </div>

            <!-- Tabs -->
            <div class="tabs">
                <button class="tab-button active" data-tab="prediction">
                    📊 Prédiction
                </button>
                <button class="tab-button" data-tab="historique">
                    📈 Historique
                </button>
                <button class="tab-button" data-tab="infos">
                    ℹ️ Infos
                </button>
                <button class="tab-button" data-tab="import">
                    📤 Import
                </button>
                <button class="tab-button" data-tab="analyse">
                    🔍 Analyse
                </button>
                <button class="tab-button" data-tab="feedback">
                    ✓ Feedback
                </button>
                <button class="tab-button" data-tab="dashboard">
                    📈 Dashboard
                </button>
            </div>

            <!-- TAB 1: Prediction -->
            <div id="prediction" class="tab-content active">
                <div class="form-container">
                    <h2>Nouvelle Course</h2>
                    
                    <!-- Race Info -->
                    <div class="form-section">
                        <h3>Informations de la Course</h3>
                        <div class="form-row">
                            <div class="form-group">
                                <label for="raceDate">Date de la course</label>
                                <input type="date" id="raceDate" value="2026-06-03">
                            </div>
                            <div class="form-group">
                                <label for="hippodrome">Hippodrome</label>
                                <input type="text" id="hippodrome" placeholder="ex: LAVAL" value="LAVAL">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label for="distance">Distance (m)</label>
                                <input type="number" id="distance" placeholder="2850" value="2850">
                            </div>
                            <div class="form-group">
                                <label for="raceType">Type de course</label>
                                <input type="text" id="raceType" placeholder="ex: ATTELE" value="ATTELE">
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="conditions">Conditions / Nom course</label>
                            <input type="text" id="conditions" placeholder="ex: GRAND NATIONAL DU TROT" value="GRAND NATIONAL DU TROT">
                        </div>
                    </div>

                    <!-- Horses Table -->
                    <div class="form-section">
                        <h3>Chevaux en Lice</h3>
                        <div class="horses-table-container">
                            <table class="horses-table">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Nom du Cheval</th>
                                        <th>Description / Analyse</th>
                                        <th>Cotes (ex: 77/1)</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="horsesTableBody">
                                    <!-- Populated by JavaScript -->
                                </tbody>
                            </table>
                        </div>
                        <div class="button-group">
                            <button class="btn btn-secondary" onclick="addHorse()">➕ Ajouter Cheval</button>
                            <button class="btn btn-secondary" onclick="removeLastHorse()">➖ Retirer Dernier</button>
                        </div>
                    </div>

                    <!-- Prediction Button -->
                    <div class="form-actions">
                        <button class="btn btn-primary btn-large" onclick="makePrediction()">
                            🔮 Générer Pronostic
                        </button>
                    </div>
                </div>

                <!-- Results -->
                <div id="resultsContainer" class="results-container hidden">
                    <h2>📋 Résultats du Pronostic</h2>
                    
                    <div class="results-summary">
                        <div class="summary-item">
                            <h4>Favori</h4>
                            <p id="winnerName" class="winner-name">-</p>
                            <p id="winnerProb" class="winner-prob">-</p>
                        </div>
                        <div class="summary-item">
                            <h4>Podium Probable</h4>
                            <p id="podium">-</p>
                        </div>
                    </div>

                    <!-- Predictions Chart -->
                    <div class="chart-container">
                        <canvas id="predictionsChart"></canvas>
                    </div>

                    <!-- Predictions Table -->
                    <table class="results-table">
                        <thead>
                            <tr>
                                <th>Rang</th>
                                <th>Numéro</th>
                                <th>Nom du Cheval</th>
                                <th>Cotes (Décimal)</th>
                                <th>Proba. Marché (%)</th>
                                <th>Prédiction (%)</th>
                                <th>Confiance</th>
                            </tr>
                        </thead>
                        <tbody id="resultsTableBody">
                            <!-- Populated by JavaScript -->
                        </tbody>
                    </table>

                    <div class="form-actions">
                        <button class="btn btn-secondary" onclick="downloadResults()">⬇️ Télécharger</button>
                        <button class="btn btn-secondary" onclick="resetForm()">🔄 Nouvelle Analyse</button>
                    </div>
                </div>
            </div>

            <!-- TAB 2: Historique -->
            <div id="historique" class="tab-content">
                <h2>Historique des Prédictions</h2>
                <div id="historiqueContainer" class="historique-container">
                    <p>Chargement de l'historique...</p>
                </div>
            </div>

            <!-- TAB 3: Infos -->
            <div id="infos" class="tab-content">
                <h2>À Propos</h2>
                <div class="info-section">
                    <h3>🤖 Système de Prédiction Intelligent</h3>
                    <p>
                        Ce système utilise un <strong>réseau de neurones profond (Deep Learning)</strong> 
                        entraîné pour prédire les résultats des courses hippiques.
                    </p>
                    
                    <h4>🔍 Facteurs Analysés:</h4>
                    <ul>
                        <li><strong>Cotes de paris:</strong> Probabilités implicites du marché</li>
                        <li><strong>Sentiment de texte:</strong> Analyse positive/négative des descriptions</li>
                        <li><strong>Mots-clés:</strong> Mentions de victoires, podiums, expérience</li>
                        <li><strong>Historique:</strong> Performances passées du cheval</li>
                        <li><strong>Confiance:</strong> Niveau d'assurance dans la prédiction</li>
                    </ul>

                    <h4>📊 Architecture du Modèle:</h4>
                    <ul>
                        <li>Input: Features textuelles + probabilités des cotes</li>
                        <li>Hidden Layers: 128 → 64 → 32 neurones + Dropout</li>
                        <li>Output: Softmax (probabilities summing to 100%)</li>
                        <li>Loss: Binary Crossentropy + Régularisation L2</li>
                    </ul>

                    <h4>⚠️ Limitations:</h4>
                    <ul>
                        <li>Les prédictions sont basées sur les données d'entraînement</li>
                        <li>Les facteurs imprévisibles (météo, forme du jour) ne peuvent pas être captés</li>
                        <li>Les résultats réels dépendent de nombreuses variables non contrôlables</li>
                        <li>⚠️ Aucune garantie de profit - à utiliser à titre informatif uniquement</li>
                    </ul>

                    <h4>💡 Conseils d'Utilisation:</h4>
                    <ul>
                        <li>Compléter les descriptions avec des informations précises</li>
                        <li>Vérifier les cotes auprès de sources officielles</li>
                        <li>Combiner avec votre propre analyse</li>
                        <li>Ne jamais parier plus que vous ne pouvez vous permettre de perdre</li>
                    </ul>
                </div>
            </div>

            <!-- TAB 4: Import Data -->
            <div id="import" class="tab-content">
                <h2>📤 Importer Données Historiques</h2>
                <div class="import-container">
                    <div class="form-section">
                        <h3>Charger des Données PDF/CSV</h3>
                        <p>Importez un fichier CSV ou PDF contenant l'historique des courses pour améliorer le modèle.</p>
                        
                        <div class="form-group">
                            <label for="importFile">Sélectionnez un fichier:</label>
                            <input type="file" id="importFile" accept=".csv,.pdf,.txt">
                        </div>
                        
                        <div class="button-group">
                            <button class="btn btn-primary" onclick="importFile()">📥 Importer Fichier</button>
                        </div>
                    </div>

                    <div id="importResults" class="import-results hidden">
                        <h3>Résultats de l'Import</h3>
                        <div id="importStats" class="stats-grid">
                            <div class="stat-item">
                                <h4>Courses Importées</h4>
                                <p id="importedCount">-</p>
                            </div>
                            <div class="stat-item">
                                <h4>Records Totaux</h4>
                                <p id="totalCount">-</p>
                            </div>
                        </div>

                        <div class="import-preview">
                            <h4>Aperçu des Données</h4>
                            <div id="importPreviewTable" class="table-container">
                                <!-- Populated by JavaScript -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- TAB 5: Analyse Corrélations -->
            <div id="analyse" class="tab-content">
                <h2>🔍 Analyse des Corrélations</h2>
                <div class="analyse-container">
                    <div class="button-group">
                        <button class="btn btn-primary" onclick="loadAnalysis()">🔄 Lancer Analyse</button>
                    </div>

                    <div id="analysisResults" class="analysis-results hidden">
                        <h3>Facteurs Prédictifs Identifiés</h3>
                        <p class="info-text">Voici les facteurs qui présentent la plus forte corrélation avec les victoires.</p>

                        <div class="analysis-section">
                            <h4>🏆 Top 10 Facteurs</h4>
                            <table class="analysis-table">
                                <thead>
                                    <tr>
                                        <th>Rang</th>
                                        <th>Facteur</th>
                                        <th>Corrélation</th>
                                        <th>Force</th>
                                        <th>Direction</th>
                                    </tr>
                                </thead>
                                <tbody id="factorsTableBody">
                                    <!-- Populated by JavaScript -->
                                </tbody>
                            </table>
                        </div>

                        <div class="analysis-section">
                            <h4>📊 Groupes de Facteurs</h4>
                            <div id="featureGroups" class="feature-groups">
                                <!-- Populated by JavaScript -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- TAB 6: Feedback -->
            <div id="feedback" class="tab-content">
                <h2>✓ Soumettre Feedback Résultats</h2>
                <div class="feedback-container">
                    <div class="form-section">
                        <h3>Enregistrer les Résultats Réels</h3>
                        <p>Saisissez les résultats réels pour améliorer continuellement le modèle.</p>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="feedbackRaceId">ID Course</label>
                                <input type="number" id="feedbackRaceId" placeholder="ex: 1">
                            </div>
                            <div class="form-group">
                                <label for="feedbackHorseId">ID Cheval</label>
                                <input type="number" id="feedbackHorseId" placeholder="ex: 5">
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="feedbackRank">Rang Prédit</label>
                                <input type="number" id="feedbackRank" placeholder="ex: 1" min="1">
                            </div>
                            <div class="form-group">
                                <label for="feedbackActual">Position Réelle</label>
                                <input type="number" id="feedbackActual" placeholder="ex: 2" min="1">
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="feedbackNotes">Notes (optionnel)</label>
                            <textarea id="feedbackNotes" placeholder="ex: Conditions météo difficiles..."></textarea>
                        </div>

                        <div class="button-group">
                            <button class="btn btn-primary" onclick="submitFeedback()">✓ Soumettre Feedback</button>
                        </div>
                    </div>

                    <div id="feedbackHistory" class="feedback-history hidden">
                        <h3>Historique du Feedback</h3>
                        <table class="feedback-table">
                            <thead>
                                <tr>
                                    <th>Course</th>
                                    <th>Cheval</th>
                                    <th>Prédit</th>
                                    <th>Réel</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody id="feedbackTableBody">
                                <!-- Populated by JavaScript -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- TAB 7: Dashboard -->
            <div id="dashboard" class="tab-content">
                <h2>📈 Dashboard Performance</h2>
                <div class="dashboard-container">
                    <div class="button-group">
                        <button class="btn btn-primary" onclick="loadDashboard()">🔄 Rafraîchir Dashboard</button>
                        <button class="btn btn-secondary" onclick="triggerRetrain()">🤖 Réentraîner Modèle</button>
                    </div>

                    <div id="dashboardMetrics" class="dashboard-metrics hidden">
                        <div class="metrics-grid">
                            <div class="metric-card">
                                <h4>Précision Globale</h4>
                                <p id="dashAccuracy" class="metric-value">-</p>
                            </div>
                            <div class="metric-card">
                                <h4>Prédictions</h4>
                                <p id="dashTotal" class="metric-value">-</p>
                            </div>
                            <div class="metric-card">
                                <h4>Correctes</h4>
                                <p id="dashCorrect" class="metric-value">-</p>
                            </div>
                            <div class="metric-card">
                                <h4>Tendance</h4>
                                <p id="dashTrend" class="metric-value">-</p>
                            </div>
                        </div>

                        <div class="chart-container">
                            <h4>📊 Évolution de la Précision</h4>
                            <canvas id="accuracyChart"></canvas>
                        </div>

                        <div class="analysis-section">
                            <h4>💡 Recommandations</h4>
                            <ul id="recommendations" class="recommendations">
                                <!-- Populated by JavaScript -->
                            </ul>
                        </div>

                        <div class="analysis-section">
                            <h4>🎯 Meilleurs Facteurs</h4>
                            <table class="factors-table">
                                <thead>
                                    <tr>
                                        <th>Facteur</th>
                                        <th>Corrélation</th>
                                        <th>Force</th>
                                    </tr>
                                </thead>
                                <tbody id="topFactorsBody">
                                    <!-- Populated by JavaScript -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </main>

        <footer>
            <p>🔐 Données traitées localement | 🧠 Modèle Deep Learning | 📅 2026</p>
        </footer>
    </div>

    <script src="script.js"></script>
</body>
</html>
